# Copy this file to .env and fill in your own keys.
# .env is git-ignored — do not commit it.

# Cerebras Cloud SDK key (used by apps/raven/cerebra.py for fast LLM chat)
# Get one at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Google Gemini API key (used by apps/raven/raven_core for the long-running agent)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
