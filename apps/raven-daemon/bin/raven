#!/usr/bin/env node

/**
 * Raven CLI
 * Command-line tool for managing the Raven voice assistant
 */

const http = require('http');
const path = require('path');
const { spawn, execSync } = require('child_process');
const fs = require('fs');

const PORT = process.env.RAVEN_DAEMON_PORT || 7433;
const BASE_URL = `http://127.0.0.1:${PORT}`;
const DAEMON_DIR = path.resolve(__dirname, '..');
const PID_FILE = path.join(process.env.HOME, '.raven', 'daemon.pid');

// Colors for terminal output
const colors = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  dim: '\x1b[2m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  red: '\x1b[31m',
  cyan: '\x1b[36m',
  magenta: '\x1b[35m',
};

function log(message, color = '') {
  console.log(`${color}${message}${colors.reset}`);
}

function logError(message) {
  log(`Error: ${message}`, colors.red);
}

function logSuccess(message) {
  log(`✓ ${message}`, colors.green);
}

function logInfo(message) {
  log(`→ ${message}`, colors.cyan);
}

/**
 * Make HTTP request to daemon
 */
function request(method, endpoint, body = null) {
  return new Promise((resolve, reject) => {
    const url = new URL(endpoint, BASE_URL);
    const options = {
      hostname: url.hostname,
      port: url.port,
      path: url.pathname,
      method,
      headers: {
        'Content-Type': 'application/json',
      },
      timeout: 5000,
    };

    const req = http.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => (data += chunk));
      res.on('end', () => {
        try {
          resolve({ status: res.statusCode, data: JSON.parse(data) });
        } catch {
          resolve({ status: res.statusCode, data });
        }
      });
    });

    req.on('error', (err) => {
      if (err.code === 'ECONNREFUSED') {
        reject(new Error('Daemon not running'));
      } else {
        reject(err);
      }
    });

    req.on('timeout', () => {
      req.destroy();
      reject(new Error('Request timeout'));
    });

    if (body) {
      req.write(JSON.stringify(body));
    }
    req.end();
  });
}

/**
 * Check if daemon is running
 */
async function isDaemonRunning() {
  try {
    await request('GET', '/health');
    return true;
  } catch {
    return false;
  }
}

/**
 * Start the daemon process
 */
async function startDaemon() {
  if (await isDaemonRunning()) {
    return true;
  }

  logInfo('Starting Raven daemon...');

  const distIndex = path.join(DAEMON_DIR, 'dist', 'index.js');
  if (!fs.existsSync(distIndex)) {
    logError('Daemon not built. Run: cd apps/raven-daemon && npm run build');
    return false;
  }

  const daemon = spawn('node', [distIndex], {
    cwd: DAEMON_DIR,
    detached: true,
    stdio: 'ignore',
  });

  daemon.unref();

  // Wait for daemon to start
  for (let i = 0; i < 20; i++) {
    await new Promise((r) => setTimeout(r, 250));
    if (await isDaemonRunning()) {
      logSuccess('Daemon started');
      return true;
    }
  }

  logError('Failed to start daemon');
  return false;
}

/**
 * Stop the daemon process
 */
async function stopDaemon() {
  if (fs.existsSync(PID_FILE)) {
    try {
      const pid = parseInt(fs.readFileSync(PID_FILE, 'utf-8').trim(), 10);
      process.kill(pid, 'SIGTERM');
      logSuccess('Daemon stopped');
      return true;
    } catch (err) {
      // Process might already be dead
    }
  }

  // Try pkill as fallback
  try {
    execSync('pkill -f "raven-daemon/dist/index.js"', { stdio: 'ignore' });
    logSuccess('Daemon stopped');
    return true;
  } catch {
    return false;
  }
}

/**
 * Commands
 */
const commands = {
  async start(args) {
    const mode = args[0] || 'screen';
    if (!['camera', 'screen', 'none'].includes(mode)) {
      logError('Invalid mode. Use: camera, screen, or none');
      return;
    }

    if (!(await startDaemon())) {
      return;
    }

    try {
      const { data } = await request('POST', '/start', { mode });
      if (data.status === 'running' || data.status === 'starting') {
        logSuccess(`Raven started in ${mode} mode`);
        if (data.pid) {
          logInfo(`PID: ${data.pid}`);
        }
      } else if (data.error) {
        logError(data.error);
      }
    } catch (err) {
      logError(err.message);
    }
  },

  async stop() {
    try {
      const { data } = await request('POST', '/stop');
      if (data.status === 'stopped') {
        logSuccess('Raven stopped');
      }
    } catch (err) {
      if (err.message === 'Daemon not running') {
        logInfo('Raven is not running');
      } else {
        logError(err.message);
      }
    }
  },

  async restart(args) {
    await commands.stop();
    await new Promise((r) => setTimeout(r, 500));
    await commands.start(args);
  },

  async status() {
    try {
      const { data } = await request('GET', '/status');
      console.log();
      log('  Raven Status', colors.bright);
      console.log('  ────────────────────');

      const statusColors = {
        running: colors.green,
        stopped: colors.dim,
        starting: colors.yellow,
        stopping: colors.yellow,
        error: colors.red,
      };

      const statusColor = statusColors[data.status] || colors.reset;
      log(`  Status:      ${statusColor}${data.status}${colors.reset}`);
      log(`  Mode:        ${data.visualMode || 'none'}`);

      if (data.pid) {
        log(`  PID:         ${data.pid}`);
      }
      if (data.startedAt) {
        const started = new Date(data.startedAt);
        const uptime = Math.floor((Date.now() - started.getTime()) / 1000);
        const hours = Math.floor(uptime / 3600);
        const mins = Math.floor((uptime % 3600) / 60);
        const secs = uptime % 60;
        log(`  Uptime:      ${hours}h ${mins}m ${secs}s`);
      }
      if (data.error) {
        log(`  Error:       ${colors.red}${data.error}${colors.reset}`);
      }
      console.log();
    } catch (err) {
      if (err.message === 'Daemon not running') {
        console.log();
        log('  Raven Status', colors.bright);
        console.log('  ────────────────────');
        log(`  Status:      ${colors.dim}offline${colors.reset}`);
        log(`  Daemon:      ${colors.dim}not running${colors.reset}`);
        console.log();
      } else {
        logError(err.message);
      }
    }
  },

  async mode(args) {
    const mode = args[0];
    if (!mode || !['camera', 'screen', 'none'].includes(mode)) {
      logError('Usage: raven mode <camera|screen|none>');
      return;
    }

    try {
      const { data } = await request('POST', '/mode', { mode });
      logSuccess(`Mode changed to: ${mode}`);
    } catch (err) {
      logError(err.message);
    }
  },

  async logs(args) {
    const limit = parseInt(args[0], 10) || 20;
    try {
      const { data } = await request('GET', `/transcripts?limit=${limit}`);
      console.log();
      log('  Recent Transcripts', colors.bright);
      console.log('  ────────────────────');

      if (!data.transcripts || data.transcripts.length === 0) {
        log('  No transcripts yet', colors.dim);
      } else {
        for (const entry of data.transcripts) {
          const time = new Date(entry.timestamp).toLocaleTimeString();
          const speaker = entry.speaker === 'user' ? colors.cyan : colors.magenta;
          log(`  ${colors.dim}${time}${colors.reset} ${speaker}${entry.speaker}:${colors.reset} ${entry.text}`);
        }
      }
      console.log();
    } catch (err) {
      logError(err.message);
    }
  },

  async functions(args) {
    const limit = parseInt(args[0], 10) || 20;
    try {
      const { data } = await request('GET', `/function-logs?limit=${limit}`);
      console.log();
      log('  Recent Function Calls', colors.bright);
      console.log('  ────────────────────');

      if (!data.logs || data.logs.length === 0) {
        log('  No function calls yet', colors.dim);
      } else {
        for (const entry of data.logs) {
          const time = new Date(entry.timestamp).toLocaleTimeString();
          const status = entry.error ? colors.red + '✗' : entry.result ? colors.green + '✓' : colors.yellow + '…';
          log(`  ${colors.dim}${time}${colors.reset} ${status}${colors.reset} ${entry.functionName}`);
          if (entry.durationMs) {
            log(`       ${colors.dim}${entry.durationMs}ms${colors.reset}`);
          }
        }
      }
      console.log();
    } catch (err) {
      logError(err.message);
    }
  },

  async daemon(args) {
    const action = args[0];

    if (action === 'start') {
      if (await startDaemon()) {
        // Already logged
      }
    } else if (action === 'stop') {
      // First stop Raven
      try {
        await request('POST', '/stop');
      } catch {
        // Ignore
      }
      await new Promise((r) => setTimeout(r, 500));
      await stopDaemon();
    } else if (action === 'restart') {
      await commands.daemon(['stop']);
      await new Promise((r) => setTimeout(r, 500));
      await commands.daemon(['start']);
    } else {
      logError('Usage: raven daemon <start|stop|restart>');
    }
  },

  async devices() {
    if (!(await startDaemon())) {
      return;
    }

    try {
      const { data } = await request('GET', '/audio-devices');
      console.log();
      log('  Audio Devices', colors.bright);
      console.log('  ────────────────────');

      console.log();
      log('  Input Devices (Microphones):', colors.cyan);
      if (!data.input || data.input.length === 0) {
        log('    No input devices found', colors.dim);
      } else {
        for (const device of data.input) {
          log(`    [${device.index}] ${device.name}`);
        }
      }

      console.log();
      log('  Output Devices (Speakers):', colors.cyan);
      if (!data.output || data.output.length === 0) {
        log('    No output devices found', colors.dim);
      } else {
        for (const device of data.output) {
          log(`    [${device.index}] ${device.name}`);
        }
      }
      console.log();
    } catch (err) {
      logError(err.message);
    }
  },

  async audio(args) {
    if (!(await startDaemon())) {
      return;
    }

    const action = args[0];

    // Show current config
    if (!action || action === 'show') {
      try {
        const { data } = await request('GET', '/config/audio-devices');
        console.log();
        log('  Audio Device Configuration', colors.bright);
        console.log('  ────────────────────');
        log(`  Input:   ${data.input !== null ? data.input : colors.dim + 'System Default' + colors.reset}`);
        log(`  Output:  ${data.output !== null ? data.output : colors.dim + 'System Default' + colors.reset}`);
        console.log();
        log('  Use "raven devices" to list available devices', colors.dim);
        log('  Use "raven audio input <index>" to set input device', colors.dim);
        log('  Use "raven audio output <index>" to set output device', colors.dim);
        console.log();
      } catch (err) {
        logError(err.message);
      }
      return;
    }

    // Set input device
    if (action === 'input') {
      const value = args[1];
      if (value === undefined) {
        logError('Usage: raven audio input <device-index|"default">');
        return;
      }

      const input = value === 'default' ? null : parseInt(value, 10);
      if (value !== 'default' && isNaN(input)) {
        logError('Device must be a number or "default"');
        return;
      }

      try {
        const { data: current } = await request('GET', '/config/audio-devices');
        await request('PUT', '/config/audio-devices', { input, output: current.output });
        logSuccess(`Input device set to: ${input !== null ? input : 'System Default'}`);
        logInfo('Restart Raven for changes to take effect');
      } catch (err) {
        logError(err.message);
      }
      return;
    }

    // Set output device
    if (action === 'output') {
      const value = args[1];
      if (value === undefined) {
        logError('Usage: raven audio output <device-index|"default">');
        return;
      }

      const output = value === 'default' ? null : parseInt(value, 10);
      if (value !== 'default' && isNaN(output)) {
        logError('Device must be a number or "default"');
        return;
      }

      try {
        const { data: current } = await request('GET', '/config/audio-devices');
        await request('PUT', '/config/audio-devices', { input: current.input, output });
        logSuccess(`Output device set to: ${output !== null ? output : 'System Default'}`);
        logInfo('Restart Raven for changes to take effect');
      } catch (err) {
        logError(err.message);
      }
      return;
    }

    logError('Usage: raven audio [show|input <index>|output <index>]');
  },

  help() {
    console.log(`
${colors.bright}Raven CLI${colors.reset} - Voice Assistant Control

${colors.bright}Usage:${colors.reset}
  raven <command> [options]

${colors.bright}Commands:${colors.reset}
  start [mode]      Start Raven (mode: camera, screen, none)
  stop              Stop Raven
  restart [mode]    Restart Raven
  status            Show Raven status
  mode <mode>       Change visual mode
  logs [limit]      Show recent transcripts
  functions [limit] Show recent function calls
  devices           List available audio devices
  audio [action]    Show/set audio device configuration
  daemon <action>   Manage daemon (start, stop, restart)
  help              Show this help

${colors.bright}Audio Commands:${colors.reset}
  raven devices              List all audio input/output devices
  raven audio                Show current audio device settings
  raven audio input <index>  Set input device by index
  raven audio output <index> Set output device by index
  raven audio input default  Reset to system default input
  raven audio output default Reset to system default output

${colors.bright}Examples:${colors.reset}
  raven start           Start with screen mode (default)
  raven start camera    Start with camera mode
  raven status          Check if Raven is running
  raven logs 50         Show last 50 transcript entries
  raven devices         List available audio devices
  raven audio input 2   Use audio input device at index 2
  raven daemon restart  Restart the background daemon
`);
  },
};

// Main
async function main() {
  const args = process.argv.slice(2);
  const command = args[0] || 'help';
  const commandArgs = args.slice(1);

  if (commands[command]) {
    await commands[command](commandArgs);
  } else {
    logError(`Unknown command: ${command}`);
    commands.help();
  }
}

main().catch((err) => {
  logError(err.message);
  process.exit(1);
});
