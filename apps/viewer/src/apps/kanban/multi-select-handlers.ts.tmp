  // Multi-select card click handler
  const handleCardClick = useCallback((cardId: string, columnId: string, e: React.MouseEvent) => {
    e.stopPropagation();

    if (e.shiftKey && lastClickedCardId) {
      const allCards = getAllCardsFlat();
      const lastIndex = allCards.findIndex(c => c.card.id === lastClickedCardId);
      const currentIndex = allCards.findIndex(c => c.card.id === cardId);

      if (lastIndex !== -1 && currentIndex !== -1) {
        const start = Math.min(lastIndex, currentIndex);
        const end = Math.max(lastIndex, currentIndex);
        const rangeIds = allCards.slice(start, end + 1).map(c => c.card.id);
        setSelectedCardIds(prev => new Set([...prev, ...rangeIds]));
      }
    } else if (e.metaKey || e.ctrlKey) {
      setSelectedCardIds(prev => {
        const next = new Set(prev);
        if (next.has(cardId)) {
          next.delete(cardId);
        } else {
          next.add(cardId);
        }
        return next;
      });
    } else {
      if (selectedCardIds.size === 1 && selectedCardIds.has(cardId)) {
        setSelectedCardIds(new Set());
      } else {
        setSelectedCardIds(new Set([cardId]));
      }
    }
    setLastClickedCardId(cardId);
  }, [lastClickedCardId, getAllCardsFlat, selectedCardIds]);

  const handleBulkMove = useCallback((targetColumnId: string) => {
    if (!board || selectedCardIds.size === 0) return;

    const cardsToMove: KanbanCard[] = [];
    board.columns.forEach(col => {
      col.cards.forEach(card => {
        if (selectedCardIds.has(card.id)) {
          cardsToMove.push(card);
        }
      });
    });

    const next: KanbanBoardData = {
      ...board,
      columns: board.columns.map(col => {
        if (col.id === targetColumnId) {
          return {
            ...col,
            cards: [...cardsToMove.map(c => ({ ...c, updatedAt: new Date().toISOString() })), ...col.cards.filter(c => !selectedCardIds.has(c.id))],
          };
        }
        return {
          ...col,
          cards: col.cards.filter(c => !selectedCardIds.has(c.id)),
        };
      }),
    };

    markDirty(next);
    setSelectedCardIds(new Set());
  }, [board, selectedCardIds, markDirty]);

  const handleBulkArchive = useCallback(() => {
    if (!board || selectedCardIds.size === 0) return;

    const archivedCards: KanbanCard[] = [];
    const now = new Date().toISOString();

    board.columns.forEach(col => {
      col.cards.forEach(card => {
        if (selectedCardIds.has(card.id)) {
          archivedCards.push({
            ...card,
            isArchived: true,
            updatedAt: now,
          });
        }
      });
    });

    const next: KanbanBoardData = {
      ...board,
      columns: board.columns.map(col => ({
        ...col,
        cards: col.cards.filter(c => !selectedCardIds.has(c.id)),
      })),
      archivedCards: [...(board.archivedCards || []), ...archivedCards],
    };

    markDirty(next);
    setSelectedCardIds(new Set());
  }, [board, selectedCardIds, markDirty]);

  const handleBulkSetPriority = useCallback((priority: Priority) => {
    if (!board || selectedCardIds.size === 0) return;

    const next: KanbanBoardData = {
      ...board,
      columns: board.columns.map(col => ({
        ...col,
        cards: col.cards.map(card =>
          selectedCardIds.has(card.id)
            ? { ...card, priority, updatedAt: new Date().toISOString() }
            : card
        ),
      })),
    };

    markDirty(next);
    setSelectedCardIds(new Set());
  }, [board, selectedCardIds, markDirty]);
